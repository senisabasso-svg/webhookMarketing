# Puerto del servidor (Railway lo setea automáticamente)
PORT=3000

# PostgreSQL — en Railway se inyecta al vincular el plugin Postgres
DATABASE_URL=postgresql://usuario:password@localhost:5432/webhook_marketing
# En producción/Railway usar SSL (se activa solo si NODE_ENV=production o DB_SSL=true)
DB_SSL=false
NODE_ENV=development

# Token que configurás en Meta Developer Console (Webhooks > Verify Token)
VERIFY_TOKEN=tu_token_secreto_de_verificacion

# Page/Instagram access token con permisos de mensajería
META_ACCESS_TOKEN=tu_access_token_de_meta

# Versión de la Graph API (v23.0 recomendada por Meta)
META_GRAPH_VERSION=v23.0

# Google AI Studio / Gemini
GEMINI_API_KEY=tu_api_key_de_gemini
GEMINI_MODEL=gemini-2.0-flash

# Instrucciones del sistema para el bot (opcional)
GEMINI_SYSTEM_PROMPT=Eres un asistente amable de atención al cliente en Instagram. Responde de forma breve, clara y en español.

# Protege GET /logs (header x-api-key, Authorization Bearer, o ?api_key=)
LOGS_API_KEY=tu_clave_secreta_para_ver_logs
