# Google AI Studio / Gemini (obligatoria)
GEMINI_API_KEY=tu_api_key_de_gemini

# Opcionales
PORT=3000
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-flash-latest
# Prompt por defecto: src/prompts/benjamin.js (asistente de Diego / FEBROS)
# GEMINI_SYSTEM_PROMPT=...  (opcional, para sobrescribir)

# Meta / Instagram — Webhook
VERIFY_TOKEN=tu_verify_token
META_ACCESS_TOKEN=tu_page_access_token
META_GRAPH_VERSION=v23.0
IG_ACCOUNT_ID=tu_ig_account_id
IG_APP_ID=tu_app_id
IG_APP_SECRET=tu_app_secret

# facebook (Page token) | instagram (Instagram Business Login token)
META_API_HOST=instagram
