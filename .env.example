# Google AI Studio / Gemini (obligatoria — empresa legacy .env)
GEMINI_API_KEY=tu_api_key_de_gemini

# Servidor
PORT=3000
NODE_ENV=development

# PostgreSQL (Railway: referenciá el servicio Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/railway
# DATABASE_SSL=true

# Panel admin
JWT_SECRET=genera_un_secreto_largo_y_aleatorio
SUPERADMIN_EMAIL=admin@tudominio.com
SUPERADMIN_PASSWORD=tu_password_seguro
FEBROS_CLIENT_TRACKING_URL=https://tu-panel-seguimiento-febros.com
PUBLIC_BASE_URL=https://tu-app.up.railway.app

# Gemini — empresa legacy (.env)
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-flash-latest
# GEMINI_SYSTEM_PROMPT=  (opcional; por defecto usa src/prompts/benjamin.js)

# Meta / Instagram — empresa legacy (.env)
VERIFY_TOKEN=tu_verify_token
META_ACCESS_TOKEN=tu_page_access_token
META_GRAPH_VERSION=v25.0
IG_ACCOUNT_ID=tu_ig_account_id
IG_APP_ID=tu_app_id
IG_APP_SECRET=tu_app_secret
META_APP_SECRET=tu_app_secret
META_API_HOST=instagram

# Meta / WhatsApp — empresa legacy (.env)
WHATSAPP_TOKEN=tu_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_GRAPH_VERSION=v21.0

# Historial de conversación IA (opcional)
CONVERSATION_HISTORY_LIMIT=20
CONVERSATION_TTL_HOURS=24

# NVIDIA — Stable Video Diffusion (superadmin)
NVIDIA_API_KEY=tu_api_key_de_nvidia
# Base GenAI (correcta para video):
NVIDIA_BASE_URL=https://ai.api.nvidia.com
NVIDIA_VIDEO_MODEL=stabilityai/stable-video-diffusion
NVIDIA_VIDEO_MODEL_PATH=/v1/genai/stabilityai/stable-video-diffusion
# Opcional: UUID de función NVCF si NVIDIA te da uno
# NVIDIA_NVCF_FUNCTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
